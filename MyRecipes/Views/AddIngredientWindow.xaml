<Window x:Class="MyRecipes.Views.AddIngredientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyRecipes.Views"
        mc:Ignorable="d"
        Title="Добавление ингредиента" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button" x:Key="AccentButtonStyle">
            <Setter Property="Background" Value="{StaticResource AccentColor1}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentColor2}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor3}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor1}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Название ингредиента -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Название ингредиента:" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="NameTextBox" Text="{Binding Ingredient.Name, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Количество -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Количество:" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="QuantityTextBox" Text="{Binding Ingredient.Quantity, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox"/>
        </StackPanel>

        <!-- Единица измерения -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Единица измерения:" Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="UnitComboBox" Text="{Binding Ingredient.Unit, UpdateSourceTrigger=PropertyChanged}" IsEditable="True">
                <ComboBoxItem Content="г"/>
                <ComboBoxItem Content="кг"/>
                <ComboBoxItem Content="мл"/>
                <ComboBoxItem Content="л"/>
                <ComboBoxItem Content="шт"/>
                <ComboBoxItem Content="ст.л."/>
                <ComboBoxItem Content="ч.л."/>
                <ComboBoxItem Content="по вкусу"/>
            </ComboBox>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,20,0,0">
            <Button Content="Добавить" Command="{Binding AddCommand}" Style="{StaticResource AccentButtonStyle}" IsDefault="True"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Style="{StaticResource AccentButtonStyle}" Background="#6c757d" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
