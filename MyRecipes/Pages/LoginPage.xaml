<Page x:Class="MyRecipes.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyRecipes.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Заголовок -->
            <TextBlock Text="Nyam-Nyam" FontSize="28" FontWeight="Bold"
                      Foreground="{StaticResource AccentColor1}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Вход в систему" FontSize="18" FontWeight="Normal"
                      Foreground="{StaticResource AccentColor2}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <!-- Демо-пользователи -->
            <TextBlock Text="Демо-пользователи:" FontSize="14" FontWeight="Bold"
                      Foreground="{StaticResource AccentColor1}" Margin="0,0,0,8"/>
            <TextBlock Text="• Admin: логин 'admin', пароль 'admin'"
                      FontSize="13" Foreground="{StaticResource AccentColor1}" Margin="0,0,0,3"/>
            <TextBlock Text="• User: логин 'user', пароль 'user'"
                      FontSize="13" Foreground="{StaticResource AccentColor1}" Margin="0,0,0,25"/>

            <!-- Логин -->
            <TextBlock Text="Логин:" FontSize="14" FontWeight="Bold"
                      Foreground="{StaticResource AccentColor1}" Margin="0,0,0,8"/>
            <TextBox x:Name="LoginTextBox" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                    Height="35" FontSize="14" Margin="0,0,0,15"/>

            <!-- Пароль -->
            <TextBlock Text="Пароль:" FontSize="14" FontWeight="Bold"
                      Foreground="{StaticResource AccentColor1}" Margin="0,0,0,8"/>
            <PasswordBox x:Name="PasswordBox" Height="35" FontSize="14"
                       Margin="0,0,0,15"
                       PasswordChanged="PasswordBox_PasswordChanged"/>

            <!-- Капча -->
            <TextBlock Text="Введите символы с картинки:" FontSize="14" FontWeight="Bold"
                      Foreground="{StaticResource AccentColor1}" Margin="0,15,0,8"/>
            <Frame x:Name="CaptchaFrame" Height="70" Margin="0,0,0,10"/>

            <TextBox x:Name="CaptchaTextBox" Text="{Binding CaptchaInput, UpdateSourceTrigger=PropertyChanged}"
                    Height="35" FontSize="14" Margin="0,0,0,25"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="ВОЙТИ" Command="{Binding LoginCommand}"
                       Style="{StaticResource AccentButtonStyle}"
                       Width="120" Height="40" Margin="0,0,15,0"/>
                <Button Content="КАПЧА" Command="{Binding RefreshCaptchaCommand}"
                       Style="{StaticResource AccentButtonStyle}"
                       Width="120" Height="40"/>
            </StackPanel>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="ErrorTextBlock" Text="{Binding ErrorMessage}"
                      Foreground="Red" FontSize="13" FontWeight="Bold"
                      HorizontalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Page>
