<Page x:Class="MyRecipes.Pages.PageListDishes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyRecipes.Pages"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="PageListDishes">
    <Page.Resources>
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Background" Value="{StaticResource AccentColor1}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentColor2}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Список блюд" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource AccentColor1}" HorizontalAlignment="Center"
                   Margin="0,0,0,20" Grid.Row="0"/>

        <!-- Фильтры -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="CategoryComboBox" ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name"
                         Width="150" Margin="0,0,20,0"/>

                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Width="200" Margin="0,0,10,0"/>
                <Button Content="Найти" Command="{Binding SearchCommand}"
                        Style="{StaticResource ActionButtonStyle}" Width="100"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Добавить блюдо" Command="{Binding AddDishCommand}"
                    Style="{StaticResource ActionButtonStyle}" Width="150" Height="35"
                    Visibility="{Binding IsAdminVisibility}"/>
        </Grid>

        <!-- Список блюд -->
        <ListView Grid.Row="2" ItemsSource="{Binding CurrentPageDishes}"
                  SelectedItem="{Binding SelectedDish}" BorderThickness="1"
                  BorderBrush="{StaticResource AccentColor3}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Изображение" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Photo, Converter={StaticResource ImageConverter}}"
                                       Width="80" Height="60" Stretch="UniformToFill"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Название" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                         Foreground="{StaticResource AccentColor1}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Категория" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Category.Name}"
                                         Background="{Binding Category.BackColor}"
                                         Padding="5,2" Foreground="Black"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Стоимость" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TotalCost, StringFormat={}{0:N2} руб.}"
                                         Foreground="{StaticResource AccentColor2}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Действия" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Просмотр" ToolTip="Просмотр"
                                            Command="{Binding DataContext.ViewDishCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}" Margin="2"/>
                                    <Button Content="Редактировать" ToolTip="Редактировать"
                                            Command="{Binding DataContext.EditDishCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}" Margin="2"/>
                                    <Button Content="Удалить" ToolTip="Удалить"
                                            Command="{Binding DataContext.DeleteDishCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}" Margin="2"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Пагинация -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="⏮" Command="{Binding FirstPageCommand}" Style="{StaticResource ActionButtonStyle}" Width="40"/>
            <Button Content="◀" Command="{Binding PreviousPageCommand}" Style="{StaticResource ActionButtonStyle}" Width="40"/>

            <ItemsControl ItemsSource="{Binding PageNumbers}" Margin="10,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}" Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}" Style="{StaticResource ActionButtonStyle}" Width="40"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content=">" Command="{Binding NextPageCommand}" Style="{StaticResource ActionButtonStyle}" Width="40"/>
            <Button Content=">>" Command="{Binding LastPageCommand}" Style="{StaticResource ActionButtonStyle}" Width="40"/>
        </StackPanel>
    </Grid>
</Page>
