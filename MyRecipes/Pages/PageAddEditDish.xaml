<Page x:Class="MyRecipes.Pages.PageAddEditDish"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyRecipes.Pages"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="PageAddEditDish">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor3}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor1}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="{Binding WindowTitle}" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource AccentColor1}" HorizontalAlignment="Center"
                   Margin="0,0,0,20" Grid.Row="0"/>

        <!-- Название блюда -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Название блюда:" Style="{StaticResource LabelStyle}"/>
            <TextBox Text="{Binding Dish.Name, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Категория -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Категория:" Style="{StaticResource LabelStyle}"/>
            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                     DisplayMemberPath="Name" Margin="0,0,0,10"/>
        </StackPanel>

        <!-- Количество порций -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="Количество порций:" Style="{StaticResource LabelStyle}"/>
            <TextBox Text="{Binding Dish.ServingQuantity, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox"/>
        </StackPanel>

        <!-- Ссылка на рецепт -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Ссылка на рецепт:" Style="{StaticResource LabelStyle}"/>
            <TextBox Text="{Binding Dish.RecipeLink, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,20,0,0">
            <Button Content="Выбрать фото" Command="{Binding SelectPhotoCommand}" Style="{StaticResource AccentButtonStyle}" Width="120" Margin="5"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Style="{StaticResource AccentButtonStyle}" Width="100" Margin="5"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Style="{StaticResource AccentButtonStyle}" Background="#6c757d" Width="100" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
